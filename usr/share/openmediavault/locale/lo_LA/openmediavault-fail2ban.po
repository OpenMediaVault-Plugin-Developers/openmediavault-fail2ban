msgid ""
"A filter defines a regular expression which must match a pattern "
"corresponding to a log-in failure or any other expression."
msgstr ""
"ຕົວຕອງກຳນົດ regular expression "
"ທີ່ຕ້ອງກົງກັບຮູບແບບທີ່ກ່ຽວຂ້ອງກັບການເຂົ້າລະບົບລົ້ມເຫຼວ ຫຼື ສຳນວນອື່ນໆ."

msgid "Action"
msgstr "ການດຳເນີນການ"

msgid "An email address to receive ban messages."
msgstr "ທີ່ຢູ່ອີເມລສຳລັບຮັບຂໍ້ຄວາມແຈ້ງເຕືອນການແບນ."

msgid "Ban Time"
msgstr "ເວລາແບນ"

msgid "Ban time"
msgstr "ເວລາແບນ"

msgid "Ban time in seconds."
msgstr "ເວລາແບນເປັນວິນາທີ."

msgid ""
"Can be an IP address, a CIDR mask or a DNS host, separe with space for "
"multiple ip."
msgstr ""
"ສາມາດເປັນທີ່ຢູ່ IP, CIDR mask ຫຼື DNS host, ໃຫ້ຍະຫວ່າງເພື່ອໃສ່ຫຼາຍ IP."

msgid "Create"
msgstr "ສ້າງ"

msgid "Created jail."
msgstr "ສ້າງ Jail ແລ້ວ."

msgid "Date & Time"
msgstr "ວັນທີ ແລະ ເວລາ"

msgid "Dest email"
msgstr "ອີເມລປາຍທາງ"

msgid ""
"Duration (in seconds) for IP to be banned for. Negative number for "
"'permanent' ban. (604800 = 1 week)."
msgstr ""
"ໄລຍະເວລາ (ເປັນວິນາທີ) ທີ່ IP ຈະຖືກແບນ. ໃສ່ຄ່າລົບສຳລັບການແບນ 'ຖາວອນ'. (604800"
" = 1 ອາທິດ)."

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Edit jail."
msgstr "ແກ້ໄຂ Jail."

msgid "Enable"
msgstr "ເປີດໃຊ້ງານ"

msgid "Enabled"
msgstr "ເປີດໃຊ້ງານແລ້ວ"

msgid "Fail2ban"
msgstr "Fail2ban"

msgid "Filter"
msgstr "ຕົວຕອງ"

msgid "Find time"
msgstr "ເວລາໃນການກວດສອບ"

msgid "Ignore IP"
msgstr "IP ທີ່ຍົກເວັ້ນ"

msgid "Jails"
msgstr "Jails"

msgid "Log Path"
msgstr "ເສັ້ນທາງໄຟລ໌ລັອກ"

msgid "Log path"
msgstr "ເສັ້ນທາງໄຟລ໌ລັອກ"

msgid "Max Retry"
msgstr "ຈຳນວນຄັ້ງສູງສຸດທີ່ລອງໃໝ່"

msgid "Max retry"
msgstr "ຈຳນວນຄັ້ງສູງສຸດທີ່ລອງໃໝ່"

msgid "Message"
msgstr "ຂໍ້ຄວາມ"

msgid "Name"
msgstr "ຊື່"

msgid "No jail enabled"
msgstr ""

msgid ""
"Number of matches (i.e. value of the counter) which triggers ban action on "
"the IP."
msgstr "ຈຳນວນຄັ້ງທີ່ກົງກັນ (ຄ່າຂອງຕົວນັບ) ເຊິ່ງຈະກະຕຸ້ນການດຳເນີນການແບນ IP."

msgid "Port"
msgstr "ພອດ (Port)"

msgid "Service disabled"
msgstr "ປິດການບໍລິການແລ້ວ"

msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

msgid ""
"The counter is set to zero if no match is found within 'findtime' seconds. "
"(604800 = 1 week)."
msgstr ""
"ຕົວນັບຈະຖືກຕັ້ງເປັນສູນ ຖ້າບໍ່ພົບຂໍ້ມູນທີ່ກົງກັນພາຍໃນ 'findtime' ວິນາທີ. "
"(604800 = 1 ອາທິດ)."

msgid ""
"The log file to be scanned by the filter.  Leave blank to scan systemd."
msgstr "ໄຟລ໌ລັອກທີ່ຈະໃຫ້ຕົວຕອງກວດສອບ. ປະວ່າງໄວ້ເພື່ອໃຫ້ກວດສອບ systemd."

msgid "The name of the jail."
msgstr "ຊື່ຂອງ Jail."

msgid "The port of the jail."
msgstr "ພອດຂອງ Jail."

msgid ""
"action_= ban only / action_mw=ban & send an email / action_mwl=ban & send an"
" email with whois report and log lines."
msgstr ""
"action_= ແບນຢ່າງດຽວ / action_mw=ແບນ ແລະ ສົ່ງອີເມລ / action_mwl=ແບນ ແລະ "
"ສົ່ງອີເມລ ພ້ອມກັບລາຍງານ whois ແລະ ຂໍ້ມູນໃນລັອກ."

msgid "fail2ban"
msgstr "fail2ban"
